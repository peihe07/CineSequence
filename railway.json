{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "docker/backend/Dockerfile",
    "watchPatterns": [
      "/backend/**",
      "/docker/backend/**",
      "/railway.json"
    ]
  },
  "deploy": {
    "healthcheckPath": "/readiness",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
