# ============================================================
# Cine Sequence — Production Environment Variables
# Copy to .env.production and fill in your real values
# ============================================================

# --- Infrastructure ---
POSTGRES_DB=cinesequence
POSTGRES_USER=cinesequence
POSTGRES_PASSWORD=replace-with-a-strong-password

# --- Database / Redis ---
DATABASE_URL=postgresql+asyncpg://cinesequence:replace-with-a-strong-password@postgres:5432/cinesequence
REDIS_URL=redis://redis:6379/0

# --- External APIs ---
TMDB_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODELS=gemini-2.5-flash
RESEND_API_KEY=

# --- Auth ---
JWT_SECRET=replace-with-a-long-random-secret
MAGIC_LINK_SECRET=replace-with-another-long-random-secret
MAGIC_LINK_EXPIRY_MINUTES=15
AUTH_COOKIE_SAMESITE=none
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_DOMAIN=.example.com

# --- Storage (Cloudflare R2) ---
S3_BUCKET=cinesequence
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# --- App ---
FRONTEND_URL=https://app.example.com
API_URL=https://api.example.com
NEXT_PUBLIC_API_URL=/api
API_PROXY_TARGET=https://api.example.com
NEXT_PUBLIC_SUPPORT_URL=
ENVIRONMENT=production

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
