# ============================================================
# Cine Sequence — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://dev:dev@localhost:5432/cinesequence
REDIS_URL=redis://localhost:6379/0

# --- External APIs ---
TMDB_API_KEY=
GEMINI_API_KEY=
RESEND_API_KEY=

# --- Auth ---
JWT_SECRET=change-me-to-a-random-string
MAGIC_LINK_SECRET=change-me-to-another-random-string
MAGIC_LINK_EXPIRY_MINUTES=15

# --- Storage (Cloudflare R2) ---
S3_BUCKET=cinesequence
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# --- App ---
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
ENVIRONMENT=development
AUTH_COOKIE_SAMESITE=lax
# For cross-site production deployments (for example Vercel frontend + Railway API),
# set AUTH_COOKIE_SAMESITE=none and AUTH_COOKIE_SECURE=true.
AUTH_COOKIE_SECURE=

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
